--- a/components/webui/flags/pref_service_flags_storage.cc
+++ b/components/webui/flags/pref_service_flags_storage.cc
@@ -87,7 +87,27 @@
 
 // static
 void PrefServiceFlagsStorage::RegisterPrefs(PrefRegistrySimple* registry) {
-  registry->RegisterListPref(prefs::kAboutFlagsEntries);
+  // Enable a set of recommended ungoogled-chromium flags by default. These
+  // act as pref defaults: they apply until the user changes any flag in
+  // chrome://flags (at which point the full list is written to Local State).
+  base::ListValue default_flags;
+  default_flags.Append("disable-search-engine-collection");
+  default_flags.Append("enable-parallel-downloading@1");
+  default_flags.Append("extension-mime-request-handling@2");
+  default_flags.Append("fingerprinting-canvas-image-data-noise");
+  default_flags.Append("fingerprinting-canvas-measuretext-noise");
+  default_flags.Append("fingerprinting-client-rects-noise");
+  default_flags.Append("force-punycode-hostnames");
+  default_flags.Append("increase-incognito-storage-quota@1");
+  default_flags.Append("minimal-referrers@1");
+  default_flags.Append("popups-to-tabs");
+  default_flags.Append("reduced-system-info@1");
+  default_flags.Append("remove-client-hints@1");
+  default_flags.Append("remove-tabsearch-button");
+  default_flags.Append("show-avatar-button@2");
+  default_flags.Append("spoof-webgl-info@1");
+  registry->RegisterListPref(prefs::kAboutFlagsEntries,
+                             std::move(default_flags));
   registry->RegisterDictionaryPref(prefs::kAboutFlagsOriginLists);
 }
 
