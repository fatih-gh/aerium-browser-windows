+// Copyright 2026 The Aerium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/color/aerium_color_mixer.h"
+
+#include "chrome/browser/ui/color/chrome_color_id.h"
+#include "third_party/skia/include/core/SkColor.h"
+#include "ui/color/color_id.h"
+#include "ui/color/color_mixer.h"
+#include "ui/color/color_provider.h"
+#include "ui/color/color_provider_key.h"
+#include "ui/color/color_recipe.h"
+
+void AddAeriumColorMixer(ui::ColorProvider* provider,
+                         const ui::ColorProviderKey& key) {
+  const bool dark_mode =
+      key.color_mode == ui::ColorProviderKey::ColorMode::kDark;
+  ui::ColorMixer& mixer = provider->AddMixer();
+
+  if (dark_mode) {
+    // Window frame (titlebar / area outside the tab strip).
+    mixer[ui::kColorFrameActive] = {SkColorSetRGB(0x10, 0x17, 0x30)};
+    mixer[ui::kColorFrameInactive] = {SkColorSetRGB(0x0B, 0x10, 0x26)};
+
+    // Toolbar and the active tab share a tone so they read as one surface.
+    mixer[kColorToolbar] = {SkColorSetRGB(0x1A, 0x23, 0x40)};
+    mixer[kColorTabBackgroundActiveFrameActive] = {kColorToolbar};
+    mixer[kColorTabBackgroundActiveFrameInactive] = {
+        SkColorSetRGB(0x17, 0x1E, 0x38)};
+
+    // Inactive tabs recede into the frame.
+    mixer[kColorTabBackgroundInactiveFrameActive] = {ui::kColorFrameActive};
+    mixer[kColorTabBackgroundInactiveFrameInactive] = {ui::kColorFrameInactive};
+    mixer[kColorTabBackgroundInactiveHoverFrameActive] = {
+        SkColorSetRGB(0x23, 0x2D, 0x4E)};
+    mixer[kColorTabBackgroundInactiveHoverFrameInactive] = {
+        SkColorSetRGB(0x1C, 0x25, 0x45)};
+
+    mixer[kColorToolbarBackgroundSubtleEmphasis] = {
+        SkColorSetRGB(0x23, 0x2D, 0x4E)};
+    mixer[kColorToolbarBackgroundSubtleEmphasisHovered] = {
+        SkColorSetRGB(0x2C, 0x38, 0x59)};
+  } else {
+    mixer[ui::kColorFrameActive] = {SkColorSetRGB(0xD7, 0xE3, 0xF5)};
+    mixer[ui::kColorFrameInactive] = {SkColorSetRGB(0xE9, 0xF1, 0xFB)};
+
+    mixer[kColorToolbar] = {SkColorSetRGB(0xF3, 0xF7, 0xFD)};
+    mixer[kColorTabBackgroundActiveFrameActive] = {kColorToolbar};
+    mixer[kColorTabBackgroundActiveFrameInactive] = {
+        SkColorSetRGB(0xF8, 0xFA, 0xFE)};
+
+    mixer[kColorTabBackgroundInactiveFrameActive] = {ui::kColorFrameActive};
+    mixer[kColorTabBackgroundInactiveFrameInactive] = {ui::kColorFrameInactive};
+    mixer[kColorTabBackgroundInactiveHoverFrameActive] = {
+        SkColorSetRGB(0xC3, 0xD5, 0xF0)};
+    mixer[kColorTabBackgroundInactiveHoverFrameInactive] = {
+        SkColorSetRGB(0xD2, 0xE0, 0xF2)};
+
+    mixer[kColorToolbarBackgroundSubtleEmphasis] = {
+        SkColorSetRGB(0xE4, 0xEC, 0xFA)};
+    mixer[kColorToolbarBackgroundSubtleEmphasisHovered] = {
+        SkColorSetRGB(0xD7, 0xE3, 0xF5)};
+  }
+}
