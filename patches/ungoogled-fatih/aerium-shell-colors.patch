+
+#include "ui/color/color_provider_key.h"
+
+namespace ui {
+class ColorProvider;
+}
+
+// Adds a color mixer with Aerium's hand-picked space-navy shell colors
+// (frame, toolbar, tab strip) to `provider` with `key`. Added last so it
+// overrides the stock Material/native recipes for these surfaces while
+// leaving contrast-dependent foreground colors (text, icons) to keep
+// deriving from them automatically.
+void AddAeriumColorMixer(ui::ColorProvider* provider,
+                         const ui::ColorProviderKey& key);
+
+#endif  // CHROME_BROWSER_UI_COLOR_AERIUM_COLOR_MIXER_H_
