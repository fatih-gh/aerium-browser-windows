   // Must be the last one in order to override other mixer colors.
   AddNativeChromeColorMixer(provider, key);
 
+  // Aerium: hand-picked space-navy shell colors (frame, toolbar, tab strip).
+  // Added after the native mixer so it wins by default, but before
+  // custom_theme/app_controller so an explicitly installed theme still wins.
+  AddAeriumColorMixer(provider, key);
