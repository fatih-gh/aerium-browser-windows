  public:
   UngoogledFirstRun(content::WebUI* web_ui) : content::WebUIController(web_ui) {
     content::URLDataSource::Add(Profile::FromWebUI(web_ui), std::make_unique<UFRDataSource>());
+    web_ui->RegisterMessageCallback(
