+ private:
+  // Secure DNS (dns_over_https.mode/templates) is a local-state pref, not a
+  // profile pref - it governs the whole browser's DNS resolution, not a
+  // single profile. See chrome/browser/net/stub_resolver_config_reader.cc.
+  void HandleSetSecureDns(const base::ListValue& args) {
+    if (args.size() != 2 || !args[0].is_string() || !args[1].is_string())
+      return;
+    const std::string& mode = args[0].GetString();
+    if (mode != "off" && mode != "automatic" && mode != "secure")
+      return;
+    PrefService* local_state = g_browser_process->local_state();
+    local_state->SetString(prefs::kDnsOverHttpsMode, mode);
+    local_state->SetString(prefs::kDnsOverHttpsTemplates, args[1].GetString());
+  }
